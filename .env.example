# Public PostHog project configuration. Leave the key empty for a safe no-op build.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Product origin that owns /start/google and /start/linq (for example https://remi.new).
# When absent, Google keeps its direct login and Messages is explicitly direct/unknown.
VITE_REMI_ENTRY_ORIGIN=

# The Linq destination number is configured and allowlisted in the Remi product,
# not on this public site: REMI_PUBLIC_LINQ_SIGNUP_PHONE.
