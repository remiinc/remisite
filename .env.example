# Public PostHog project configuration. Leave both empty for a safe no-op build.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Product origin that owns /start/google and /start/linq (for example https://remi.new).
# Leave empty until launch configuration is reviewed; onboarding CTAs render unavailable.
VITE_REMI_ENTRY_ORIGIN=

# The Linq destination number is intentionally configured in the Remi product,
# not this public site: REMI_PUBLIC_LINQ_SIGNUP_PHONE.
